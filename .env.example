# Required for ETH / USDT / USDC balance scanning in the Wallets view.
# Get a free key at https://etherscan.io/myapikey
# Free tier: 5 req/s — sufficient for scanning up to ~400 wallets (~2-3 min per full scan)
VITE_ETHERSCAN_API_KEY=your_etherscan_api_key_here

# If deploying under a sub-path (e.g., GitHub Pages), set the base URL for Vite.
# VITE_BASE_URL=/cryptovault-exchange/
